# Copy to .env and fill in. Never commit .env.

# MongoDB connection string
MONGODB_URI=

# Redis URL (BullMQ) — use noeviction policy on small plans; see docs/RENDER_CHECKLIST.md
REDIS_URL=

# JWT for API auth
JWT_SECRET=

# User used by automation scripts (filtered apply, mass apply, cron)
AUTO_USER_EMAIL=

# Optional: local resume path for Puppeteer uploads (cloud: prefer hosted resume URL on user profile)
RESUME_FILE_PATH=

# GitHub Actions / external cron: same secret in Render + GitHub repo secrets
# External Discovery APIs (Get free keys from Jooble/Adzuna developer portals)
JOOBLE_API_KEY=a8a8e110-98ed-450a-bcef-7f3fad610e45
ADZUNA_APP_ID=d573a838
ADZUNA_APP_KEY=749649bf56e9df9a565484f9a8623cc7
