# Copy to .env and fill in. Never commit .env.

# MongoDB connection string
MONGODB_URI=

# Redis URL (BullMQ) — use noeviction policy on small plans; see docs/RENDER_CHECKLIST.md
REDIS_URL=

# JWT for API auth
JWT_SECRET=

# User used by automation scripts (filtered apply, mass apply, cron)
AUTO_USER_EMAIL=

# Optional: local resume path for Puppeteer uploads (cloud: prefer hosted resume URL on user profile)
RESUME_FILE_PATH=

# GitHub Actions / external cron: same secret in Render + GitHub repo secrets
# POST /api/cron/hourly with Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
